# Fleet Memory — Cognee Configuration
# Copy to .env and fill in API keys before deploying.

###############################################################################
# LLM — DeepSeek v4 via OpenRouter
###############################################################################
LLM_API_KEY=sk-or-v1-your-openrouter-key
LLM_PROVIDER=custom
LLM_MODEL=openrouter/deepseek/deepseek-chat
LLM_ENDPOINT=https://openrouter.ai/api/v1

# For higher quality entity extraction (costs more):
# LLM_MODEL=openrouter/deepseek/deepseek-reasoner

# Rate limiting (tune for your OpenRouter tier)
LLM_RATE_LIMIT_ENABLED=true
LLM_RATE_LIMIT_REQUESTS=30
LLM_RATE_LIMIT_INTERVAL=60

###############################################################################
# Embeddings — Qwen3 via OpenRouter (same key, ~$0.01/1M tokens)
###############################################################################
EMBEDDING_PROVIDER=custom
EMBEDDING_MODEL=openrouter/qwen/qwen3-embedding-8b
EMBEDDING_DIMENSIONS=4096
EMBEDDING_API_KEY=sk-or-v1-your-openrouter-key

###############################################################################
# Storage — file-based defaults (no extra containers needed)
###############################################################################
DB_PROVIDER=sqlite
DB_NAME=cognee_db
GRAPH_DATABASE_PROVIDER=kuzu
GRAPH_DATASET_DATABASE_HANDLER=kuzu
VECTOR_DB_PROVIDER=lancedb
VECTOR_DATASET_DATABASE_HANDLER=lancedb

# Persistent data on GCP data disk
DATA_ROOT_DIRECTORY=/data/cognee-data/
SYSTEM_ROOT_DIRECTORY=/data/cognee-system/

###############################################################################
# Security & Runtime
###############################################################################
REQUIRE_AUTHENTICATION=False
CORS_ALLOWED_ORIGINS=*
ENV=local
LITELLM_LOG=ERROR
TOKENIZERS_PARALLELISM=false

# MCP transport
TRANSPORT_MODE=sse
