# Fleet Memory — gbrain Configuration
# Copy to .env and fill in API keys before running gbrain init.

###############################################################################
# Embeddings — OpenAI (required)
###############################################################################
OPENAI_API_KEY=sk-your-openai-key

###############################################################################
# Anthropic — for search expansion, dream cycle, subagents (optional but recommended)
###############################################################################
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

###############################################################################
# gbrain paths (on GCP data disk)
###############################################################################
GBRAIN_HOME=/data/brain
