# Fleet Memory — gbrain Configuration
# Copy to .env and fill in API keys before running gbrain init.

###############################################################################
# Option A: OpenRouter (consolidates LLM + embedding costs in one key)
###############################################################################
OPENROUTER_API_KEY=sk-or-your-openrouter-key
GBRAIN_CHAT_MODEL=openrouter:anthropic/claude-sonnet-4.6
GBRAIN_EMBEDDING_MODEL=openrouter:openai/text-embedding-3-small
GBRAIN_EMBEDDING_DIMENSIONS=1536

###############################################################################
# Option B: Direct API keys (uncomment and use instead of OpenRouter)
###############################################################################
# OPENAI_API_KEY=sk-your-openai-key
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

###############################################################################
# Anthropic direct — required only for durable subagents (gbrain agent run).
# OpenRouter-proxied Anthropic is rejected for that feature.
# Everything else (search, embed, chat, dream) works via OpenRouter.
###############################################################################
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

###############################################################################
# gbrain paths (on GCP data disk)
###############################################################################
GBRAIN_HOME=/data/brain
